{
  "hosting": [
    {
      "target": "treasurer",
      "public": "web-panel",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "*.exe"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    },
    {
      "target": "consumers",
      "public": "consumer-panel",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}